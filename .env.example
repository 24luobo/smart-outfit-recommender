# ===== AI 模型配置 =====
# 选择 provider:deepseek / zhipu / qwen / openai / ollama
LLM_PROVIDER=deepseek

# 通用 API Key(所有 provider 都会先尝试读它,再读各 provider 自己的 key)
LLM_API_KEY=

# 自定义 base_url(可选,留空则用各 provider 默认地址)
# LLM_BASE_URL=

# 自定义模型名(可选,留空则用各 provider 默认模型)
# LLM_MODEL=

# ===== 各 provider 专属 key(优先级高于 LLM_API_KEY) =====
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=
